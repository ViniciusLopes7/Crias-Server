# ============================================
# Crias-Server Global Configuration (PT-BR)
# ============================================

# Qual stack instalar por padrao.
# Valores aceitos: minecraft | terraria
SERVER_TYPE=""

# Hardware tuning:
# vazio = detecta automaticamente
# LOW | MID | HIGH = forca um tier manual
FORCE_HARDWARE_TIER=""

# Flags globais
INSTALL_TAILSCALE="true"
APPLY_SYSTEM_TUNING="true"
# host = aplica tuning global no host (sysctl/zram/scheduler/cpupower)
# none = nao aplica tuning global (use em VPS, containers, ou quando o host ja estiver otimizado)
SYSTEM_TUNING_SCOPE="host"
CLEANUP_OTHER_STACK="true"
# DRY_RUN=true evita operacoes destrutivas (pacman/useradd/systemd/cleanup).
DRY_RUN="false"
# NON_INTERACTIVE=true desativa prompts e exige SERVER_TYPE definido.
NON_INTERACTIVE="false"

# Item S8: detecção de virtualização automática.
# auto = detecta e skipa tuning em container/VPS (recomendado).
# force  = aplica tuning mesmo em container/VPS (sobrescreve SYSTEM_TUNING_SCOPE).
VIRT_TUNING_BEHAVIOR="auto"

# ============================================
# Hardware thresholds (item R1 do plano)
# ============================================
# Magic numbers movidos para config.env para facilitar tuning.
# Edite com cuidado — defaults são conservadores.
HW_LOW_TIER_MAX_RAM_MB=3072
HW_LOW_TIER_MAX_CPU_CORES=2
HW_MID_TIER_MAX_RAM_MB=12288
HW_MID_TIER_MAX_CPU_CORES=6

# ============================================
# Minecraft
# ============================================
MINECRAFT_USER="minecraft"
MINECRAFT_SERVER_DIR="/opt/minecraft-server"
MINECRAFT_PORT=25565
MINECRAFT_ONLINE_MODE="false"
MINECRAFT_VERSION="1.21.11"
MINECRAFT_LOADER="fabric"
MINECRAFT_INSTALL_MODPACK="true"
MINECRAFT_ADRENALINE_VERSION=""
MINECRAFT_INSTALL_QOL_MODS="true"

# Item R2: QoL mods configuráveis via CSV no formato "file_name:slug,file_name:slug,...".
# Defaults recomendados para Fabric+Adrenaline.
MINECRAFT_QOL_MODS="chunky:chunky,essential-commands:essential-commands,universal-graves:universal-graves,tabtps:tabtps,styled-chat:styled-chat,polymer:polymer,placeholder-api:placeholder-api"

# Item R3: modpack source configurável.
# adrenaline  = modpack Adrenaline (default)
# modrinth    = modpack genérico via MODPACK_SLUG no Modrinth
# vanilla     = instala apenas loader vanilla (sem modpack)
MINECRAFT_MODPACK_SOURCE="adrenaline"
MINECRAFT_MODPACK_SLUG="adrenaline"

# Checksums (supply chain)
# Opcional: se preenchido (64 hex), o installer valida integridade do download.
# Mods QoL seguem a mesma convensão via variáveis MOD_<NOME>_SHA256, por exemplo:
# MOD_CHUNKY_SHA256, MOD_ESSENTIAL_COMMANDS_SHA256, MOD_UNIVERSAL_GRAVES_SHA256.
MRPACK_SHA256=""

# Item S3: versão pinada do mrpack-install + checksum hardcoded.
# Não mude a versão sem atualizar o checksum correspondente.
#
# SHA256 do mrpack-install_0.21.0-beta_linux_amd64.tar.gz (release oficial):
#   718e2f9f7337cddd8992641b22e704786a5e70e744e661d51aa3494f7ddfd9d2
#
# Para verificar ou obter SHA de outra versão:
#   curl -fsSL https://github.com/nothub/mrpack-install/releases/download/<TAG>/mrpack-install_<version>_linux_amd64.tar.gz | sha256sum
MRPACK_INSTALL_VERSION="v0.21.0-beta"
MRPACK_INSTALL_SHA256="718e2f9f7337cddd8992641b22e704786a5e70e744e661d51aa3494f7ddfd9d2"

# ============================================
# Terraria (Vanilla Dedicated Server)
# ============================================
TERRARIA_USER="terraria"
TERRARIA_SERVER_DIR="/opt/terraria-server"
TERRARIA_PORT=7777
TERRARIA_WORLD_NAME="world"
TERRARIA_MOTD="Server dos Crias"

# URL do pacote oficial do servidor dedicado.
# Ajuste se o link oficial mudar.
TERRARIA_DOWNLOAD_URL="https://terraria.org/api/download/pc-dedicated-server/terraria-server-1456.zip"

# Checksums (supply chain) — obrigatório (item S2).
# Preencha com o SHA256 oficial (64 hex) do .zip.
TERRARIA_SHA256=""

# ============================================
# Backup (opcional, item 6.3 do plano)
# ============================================
# Retenção em dias (default: 7, override por tier: LOW=5, HIGH=10).
BACKUP_RETENTION_DAYS="7"
# Nível de compressão zstd (-1 a -19; default -3; mais negativo = mais rápido).
BACKUP_ZSTD_LEVEL="-3"

# Backup remoto opcional (rsync após criar o .tar.zst local).
# BACKUP_REMOTE_PATH="user@host:/path/to/backups/"
BACKUP_REMOTE_PATH=""

# Webhook opcional para notificar sucesso/falha de backup (JSON POST).
# BACKUP_NOTIFY_WEBHOOK="https://discord.com/api/webhooks/..."
BACKUP_NOTIFY_WEBHOOK=""

# ============================================
# Agente de controle remoto (Fase 1+ do plano)
# ============================================
# Defina INSTALL_AGENT=true para instalar o agente Go (crias-agent) durante
# o install.sh. Default: pergunta interativamente.
# O token de autenticação é gerado automaticamente.
INSTALL_AGENT=""
