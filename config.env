# Minecraft Server Environment Configuration
# Default values for install.sh and server scripts

MINECRAFT_USER="minecraft"
SERVER_DIR="/opt/minecraft-server"
SERVER_PORT=25565
# Java aceita inteiro com sufixo M/G (ex: 2560M, 2G). Nao use 2.5G.
SERVER_RAM="2560M"
ONLINE_MODE="false"

# Installation Toggles
INSTALL_MODPACK="true"
ADRENALINE_VERSION="" # Empty for latest
INSTALL_QOL_MODS="true"
INSTALL_TAILSCALE="true"

# World Settings
VIEW_DISTANCE=6
SIMULATION_DISTANCE=4
