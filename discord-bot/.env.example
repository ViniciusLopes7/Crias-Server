# discord-bot/.env.example
#
# Copie para .env e preencha com os valores reais.
# Em produção (Railway), defina estas variáveis no painel do Railway.

# Discord
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=123456789012345678  # opcional: guild para sync imediato de slash commands
DISCORD_ADMIN_ROLE_IDS=111111111111111111,222222222222222222
DISCORD_MODERATOR_ROLE_IDS=333333333333333333

# Canais (IDs numéricos do Discord)
DISCORD_CONTROLE_CHANNEL_ID=444444444444444444
DISCORD_CHAT_MC_CHANNEL_ID=555555555555555555
DISCORD_CONSOLE_CHANNEL_ID=666666666666666666

# Agente gRPC (crias-agent)
CRIAS_AGENT_HOST=https://seu-host.seu-tailnet.ts.net
CRIAS_AGENT_TOKEN=your_64_hex_char_token_here

# Comportamento
STATUS_CACHE_SECONDS=15
RECONNECT_MAX_DELAY=60
