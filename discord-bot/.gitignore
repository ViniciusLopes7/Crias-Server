# discord-bot/.gitignore

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Virtualenv
.venv/
venv/
env/

# Env files (NUNCA commitar secrets)
.env
.env.local
.env.production

# Código protobuf gerado (regenerar via grpc_tools.protoc)
src/crias_bot/grpc_gen/*.py
!src/crias_bot/grpc_gen/__init__.py

# Editores
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Railway
railway.json.local
