{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "discord-bot/Dockerfile",
    "watchPatterns": [
      "discord-bot/**",
      "discord-agent/proto/**"
    ]
  },
  "deploy": {
    "startCommand": "python -m crias_bot",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
